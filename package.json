{
  "name": "n8n-nodes-forecastr",
  "version": "0.2.1",
  "description": "Forecastr n8n node — verifiable AI forecasts with RFC 3161 + on-chain proof",
  "keywords": [
    "n8n-community-node-package",
    "forecastr",
    "forecast",
    "AI",
    "RFC3161"
  ],
  "license": "MIT",
  "homepage": "https://forecastr.dev",
  "author": "Forecastr",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnsreicht/n8n-nodes-forecastr"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/credentials dist/ 2>/dev/null || true",
    "dev": "tsc --watch"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ForecastrApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Forecastr/Forecastr.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "n8n-workflow": "*",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
